# Operating system files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# Editor and IDE state
.idea/
.vscode/
*.code-workspace

# Python caches and virtual environments
__pycache__/
*.py[cod]
*$py.class
.python-version
.venv/
venv/
env/
ENV/

# Test, coverage, and build output
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Local temporary files
.tmp/
tmp/
temp/
*.tmp
*.temp
*.bak
*.swp
*.swo
~$*

# Logs
*.log
logs/

# Local intake and source library assets
01_inbox/**
02_library/**
!01_inbox/**/
!02_library/**/
!01_inbox/**/.gitkeep
!02_library/**/.gitkeep

# Large source assets kept outside Git history
*.pdf
*.djvu
*.epub
*.mobi
*.azw
*.azw3
*.cbz
*.cbr
*.doc
*.docx
*.ppt
*.pptx
*.xls
*.xlsx
*.pages
*.numbers
*.key

# Archives and installers
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz
*.gz
*.bz2
*.xz
*.iso
*.exe
*.msi
*.dmg
*.pkg

# Media files
*.mp3
*.wav
*.flac
*.aac
*.m4a
*.mp4
*.mkv
*.mov
*.avi
*.webm

# OCR and extracted full-text artifacts
*.hocr
*.ocr.hocr
*.ocr.txt
*.alto.xml
02_library/**/*.txt

# Obsidian local state and personal settings
03_vault/.obsidian/**
!03_vault/.obsidian/
!03_vault/.obsidian/.gitkeep

# Secrets and local credentials
.env
.env.*
*.pem
*.p12
*.pfx
id_rsa
id_ed25519
credentials*.json
token*.json
secrets.*

# Sync conflict files
*conflicted copy*
*冲突*
*同步冲突*

# Keep intentional placeholder files trackable
!.gitkeep
